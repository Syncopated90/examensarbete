              "fullDescription": {
                "text": "\nShort Classnames with fewer than e.g. five characters are not recommended.\n        "
              },
              "helpUri": "https://docs.pmd-code.org/snapshot/pmd_rules_java_codestyle.html#shortclassname",
              "help": {
                "text": "\nShort Classnames with fewer than e.g. five characters are not recommended.\n        "
              },
