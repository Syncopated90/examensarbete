            {
              "id": "LongVariable",
              "shortDescription": {
                "text": "Avoid excessively long variable names like lastOpenedLibraries"
              },
              "fullDescription": {
                "text": "\nFields, formal arguments, or local variable names that are too long can make the code difficult to follow.\n        "
              },
