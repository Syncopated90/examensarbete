            {
              "id": "EmptyMethodInAbstractClassShouldBeAbstract",
              "shortDescription": {
                "text": "An empty method in an abstract class should be abstract instead"
              },
              "fullDescription": {
                "text": "\nEmpty or auto-generated methods in an abstract class should be tagged as abstract. This helps to remove their inappropriate\nusage by developers who should be implementing their own versions in the concrete subclasses.\n        "
              },
              "helpUri": "https://docs.pmd-code.org/snapshot/pmd_rules_java_codestyle.html#emptymethodinabstractclassshouldbeabstract",
              "help": {
                "text": "\nEmpty or auto-generated methods in an abstract class should be tagged as abstract. This helps to remove their inappropriate\nusage by developers who should be implementing their own versions in the concrete subclasses.\n        "
              },
              "properties": {
                "ruleset": "Code Style",
                "priority": 1,
                "tags": [
                  "Code Style"
                ]
              },
              "defaultConfiguration": {
                "level": "error"
              }
            },
            {
              "id": "UncommentedEmptyMethodBody",
              "shortDescription": {
                "text": "Document empty method body"
              },
              "fullDescription": {
                "text": "\nUncommented Empty Method Body finds instances where a method body does not contain\nstatements, but there is no comment. By explicitly commenting empty method bodies\nit is easier to distinguish between intentional (commented) and unintentional\nempty methods.\n        "
              },
              "helpUri": "https://docs.pmd-code.org/snapshot/pmd_rules_java_documentation.html#uncommentedemptymethodbody",
              "help": {
                "text": "\nUncommented Empty Method Body finds instances where a method body does not contain\nstatements, but there is no comment. By explicitly commenting empty method bodies\nit is easier to distinguish between intentional (commented) and unintentional\nempty methods.\n        "
              },
              "properties": {
                "ruleset": "Documentation",
                "priority": 3,
                "tags": [
                  "Documentation"
                ]
              },
              "defaultConfiguration": {
                "level": "warning"
              }
