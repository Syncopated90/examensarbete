            {
              "id": "UselessPureMethodCall",
              "shortDescription": {
                "text": "Do not call pure method truncatedTo if the result is not used."
              },
              "fullDescription": {
                "text": "\nThis rule detects method calls of pure methods whose result is unused. A pure method is a method without\nside effects. Therefore, ignoring the result of such a method call is likely a mistake.\n\nEither the method call can be removed or the result should be used.\n        "
              },
              "helpUri": "https://docs.pmd-code.org/snapshot/pmd_rules_java_errorprone.html#uselesspuremethodcall",
              "help": {
                "text": "\nThis rule detects method calls of pure methods whose result is unused. A pure method is a method without\nside effects. Therefore, ignoring the result of such a method call is likely a mistake.\n\nEither the method call can be removed or the result should be used.\n        "
              },
              "properties": {
                "ruleset": "Error Prone",
                "priority": 3,
