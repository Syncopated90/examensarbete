            {
              "id": "AvoidDuplicateLiterals",
              "shortDescription": {
                "text": "The String literal \"\\r\\n\" appears 5 times in this file; the first occurrence is on line 115"
              },
              "fullDescription": {
                "text": "\nCode containing duplicate String literals can usually be improved by declaring the String as a constant field.\n        "
              },
              "helpUri": "https://docs.pmd-code.org/snapshot/pmd_rules_java_errorprone.html#avoidduplicateliterals",
              "help": {
