            {
              "id": "UseVarargs",
              "shortDescription": {
                "text": "Consider using varargs for methods or constructors which take an array the last parameter."
              },
              "fullDescription": {
                "text": "\nJava 5 introduced the varargs parameter declaration for methods and constructors. This syntactic\nsugar provides flexibility for users of these methods and constructors, allowing them to avoid\nhaving to deal with the creation of an array.\n\nByte arrays in any method and String arrays in `public static void main(String[])` methods are ignored.\n        "
              },
              "helpUri": "https://docs.pmd-code.org/snapshot/pmd_rules_java_bestpractices.html#usevarargs",
              "help": {
                "text": "\nJava 5 introduced the varargs parameter declaration for methods and constructors. This syntactic\nsugar provides flexibility for users of these methods and constructors, allowing them to avoid\nhaving to deal with the creation of an array.\n\nByte arrays in any method and String arrays in `public static void main(String[])` methods are ignored.\n        "
              },
              "properties": {
                "ruleset": "Best Practices",
                "priority": 4,
                "tags": [
                  "Best Practices"
                ]
              },
              "defaultConfiguration": {
                "level": "note"
              }
            },
            {
              "id": "OnlyOneReturn",
              "shortDescription": {
                "text": "A method should have only one exit point, and that should be the last statement in the method"
              },
              "fullDescription": {
                "text": "\nA method should have only one exit point, and that should be the last statement in the method.\n        "
              },
              "helpUri": "https://docs.pmd-code.org/snapshot/pmd_rules_java_codestyle.html#onlyonereturn",
              "help": {
                "text": "\nA method should have only one exit point, and that should be the last statement in the method.\n        "
              },
              "properties": {
