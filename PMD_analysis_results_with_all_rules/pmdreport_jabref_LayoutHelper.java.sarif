            {
              "id": "UseUnderscoresInNumericLiterals",
              "shortDescription": {
                "text": "Number 65535 should separate every third digit with an underscore"
              },
              "fullDescription": {
                "text": "\n            Since Java 1.7, numeric literals can use underscores to separate digits. This rule enforces that\n            numeric literals above a certain length use these underscores to increase readability.\n\n            The rule only supports decimal (base 10) literals for now. The acceptable length under which literals\n            are not required to have underscores is configurable via a property. Even under that length, underscores\n            that are misplaced (not making groups of 3 digits) are reported.\n        "
              },
              "helpUri": "https://docs.pmd-code.org/snapshot/pmd_rules_java_codestyle.html#useunderscoresinnumericliterals",
              "help": {
                "text": "\n            Since Java 1.7, numeric literals can use underscores to separate digits. This rule enforces that\n            numeric literals above a certain length use these underscores to increase readability.\n\n            The rule only supports decimal (base 10) literals for now. The acceptable length under which literals\n            are not required to have underscores is configurable via a property. Even under that length, underscores\n            that are misplaced (not making groups of 3 digits) are reported.\n        "
              },
              "properties": {
                "ruleset": "Code Style",
                "priority": 3,
                "tags": [
                  "Code Style"
                ]
              },
              "defaultConfiguration": {
                "level": "warning"
              }
            }
          ]
        }
